ERP_MODE=hybrid

# API Data System
ERP_API_BASE_URL=https://seu-erp.exemplo.com/api
ERP_API_DASHBOARD_PATH=/dashboard
ERP_API_TOKEN=coloque-seu-token-aqui

# Ativa um conector reservado para regras proprietarias
ERP_CUSTOM_CONNECTOR_ENABLED=false

# Banco Data System
ERP_DB_SERVER=127.0.0.1
ERP_DB_NAME=DataSystem
ERP_DB_USER=usuario
ERP_DB_PASSWORD=senha
ERP_DB_ENCRYPT=false
ERP_DB_TRUST_SERVER_CERTIFICATE=true

# Espera 4 recordsets:
# 1. resumo: company_name, period_label, active_employees, net_revenue, revenue_target, orders_count, avg_ticket, conversion_rate
# 2. tendencia: label, value, target
# 3. ranking: collaborator, team, value, status
# 4. alertas: title, message, severity
ERP_DB_DASHBOARD_QUERY=SELECT TOP 1 'Data System' AS company_name, 'Hoje' AS period_label, 42 AS active_employees, 154000 AS net_revenue, 182000 AS revenue_target, 236 AS orders_count, 652 AS avg_ticket, 33.1 AS conversion_rate; SELECT '08h' AS label, 14000 AS value, 18000 AS target UNION ALL SELECT '09h', 18000, 20000 UNION ALL SELECT '10h', 22000, 24000 UNION ALL SELECT '11h', 27000, 25000; SELECT 'Mariana Costa' AS collaborator, 'Comercial Sul' AS team, 42900 AS value, '129% da meta' AS status UNION ALL SELECT 'Carlos Mendes', 'Inside Sales', 39200, '118% da meta'; SELECT 'Fila acima do previsto' AS title, 'Pedidos aguardando separacao subiram 14% na ultima hora.' AS message, 'high' AS severity UNION ALL SELECT 'Time Norte abaixo da meta', 'Equipe entregou 82% do planejado ate agora.', 'medium';

# Tray Ecommerce
TRAY_API_HOST=https://sua-loja.com.br/web_api
TRAY_ACCESS_TOKEN=

# Alternativa de autenticacao na Tray
TRAY_API_ADDRESS=https://sua-loja.com.br/web_api
TRAY_CONSUMER_KEY=
TRAY_CONSUMER_SECRET=
TRAY_CODE=
